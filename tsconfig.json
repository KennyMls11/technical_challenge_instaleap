{
  "compilerOptions": {
    /* 📁 Estructura */
    "rootDir": "./src",
    "outDir": "./dist",

    /* ⚙️ Entorno Node */
    "module": "commonjs",
    "target": "es2019",
    "lib": ["es2019"],
    "types": ["node"],

    /* 🔄 Interoperabilidad */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* 🧠 Calidad de código */
    "strict": true,
    "skipLibCheck": true,

    /* 🧪 Debug */
    "sourceMap": true
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}